# Server Configuration
PORT=3001
NODE_ENV=development

# API Keys
GEMINI_API_KEY=your_api_key_here

# Database Configuration
DATABASE_PATH=./db/miatech.db

# Cache Configuration
CACHE_PATH=./cache/audios/
