# ===========================================
# MiaTech Assessment - Git Ignore File
# ===========================================

# ==========================================
# ARCHIVOS SENSIBLES (NO SUBIR NUNCA)
# ==========================================
.env
.env.local
.env.production
.env.*.local
*.key
*.pem

# ==========================================
# NODE.JS
# ==========================================
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
package-lock.json

# ==========================================
# SISTEMA OPERATIVO
# ==========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ==========================================
# EDITORES DE CÓDIGO
# ==========================================
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ==========================================
# LOGS Y TEMPORALES
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# ==========================================
# CARPETAS TEMPORALES
# ==========================================
temp/
tmp/
dist/
build/
.cache/

# ==========================================
# ARCHIVOS DE RESPALDO
# ==========================================
*.bak
*.backup
*.old
*.orig